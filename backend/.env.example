# -------- App --------
APP_NAME="URL Shortener"
APP_ENV=development
DEBUG=false
# Base URL used when building short_url strings in responses.
BASE_URL=http://localhost:8000

# -------- Database (PostgreSQL) --------
# Local Docker Compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/urlshortener
# Example Supabase: postgresql+asyncpg://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
# Example Railway:  postgresql+asyncpg://postgres:<pw>@containers-us-west-X.railway.app:PORT/railway
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# -------- Redis --------
# Local Docker Compose
REDIS_URL=redis://redis:6379/0
# Example Upstash: rediss://default:<password>@<region>.upstash.io:6379
CACHE_DEFAULT_TTL=86400

# -------- Rate limiting --------
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# -------- Short IDs --------
SHORT_ID_LENGTH=7
SHORT_ID_MAX_RETRIES=5

# -------- CORS (comma-separated) --------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
